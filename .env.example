# --- Coming-soon gate -------------------------------------------------------
COMING_SOON_MODE=true

# Базовый URL для ссылок в письмах (confirm/unsubscribe).
# Прод: https://makiblitz.de · локально можно http://localhost:3000
SITE_URL=https://makiblitz.de

# --- Mail (Brevo transactional API, HTTPS — без SMTP) ------------------------
BREVO_API_KEY=               # Brevo → Settings → SMTP & API → API Keys (xkeysib-…)
MAIL_FROM=info@makiblitz.de  # ДОЛЖЕН быть верифицированным отправителем в Brevo
MAIL_FROM_NAME=MakiBlitz     # необязательно: отображаемое имя отправителя
MAIL_TO=info@makiblitz.de    # почта владельца — сюда приходят ПОДТВЕРЖДЁННЫЕ заявки и отписки

# --- Supabase (Waitlist-Status + Consent-Nachweis, Art. 7 DSGVO) ------------
# Источник истины по статусу подписчиков (pending/confirmed/unsubscribed).
# Schema: supabase/schema.sql — выполнить один раз в Supabase SQL Editor.
# Без этих переменных локально используется файловый fallback
# (waitlist-events.jsonl) — на Vercel он НЕ работает (read-only FS).
SUPABASE_URL=                  # Supabase → Project Settings → API → Project URL
SUPABASE_SERVICE_ROLE_KEY=     # service_role key — ТОЛЬКО на сервере, НЕ на клиент!

# --- Secrets (Art. 32 DSGVO) — сгенерировать: openssl rand -base64 32 --------
TOKEN_SECRET=       # HMAC-подпись confirm/unsubscribe-токенов (double-opt-in)
IP_HASH_SECRET=     # HMAC-SHA256-псевдонимизация IP; сырой IP нигде не хранится

# --- Meta (Facebook) Pixel --------------------------------------------------
# ID пикселя из Meta Events Manager. Если пусто — пиксель не грузится вообще
# (ни запросов, ни ошибок). Грузится только после согласия в Cookie-Banner.
NEXT_PUBLIC_FB_PIXEL_ID=
